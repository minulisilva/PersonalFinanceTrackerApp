<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="30dp">

    <!-- ScrollView to handle content overflow -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp">

            <!-- Title and Date -->
            <TextView
                android:id="@+id/title_financial_snapshot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Financial Snapshot"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/date_snapshot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apr 2025"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <!-- Tabs for This Week, This Month, This Year -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tab_this_week"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Week"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:padding="8dp"
                    android:background="@drawable/tab_background_selected" />

                <TextView
                    android:id="@+id/tab_this_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Month"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:padding="8dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/tab_background_unselected" />

                <TextView
                    android:id="@+id/tab_this_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Year"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:padding="8dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/tab_background_unselected" />

            </LinearLayout>

            <!-- Summary Section (Income and Expense) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Income Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/income_card_background"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/label_total_earned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Income"
                        android:textSize="16sp"
                        android:textColor="@color/income_text"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/value_total_earned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LKR 45,520"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                </LinearLayout>

                <!-- Expense Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/expense_card_background"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/label_total_spent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expense"
                        android:textSize="16sp"
                        android:textColor="@color/expense_text"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/value_total_spent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LKR 44,540"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                </LinearLayout>

            </LinearLayout>

            <!-- Net Income/Expense -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="16dp"
                android:background="@drawable/light_purple_gradient"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Net Income"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <TextView
                    android:id="@+id/value_net_income"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LKR 980.50"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Weekly Comparison Section -->
            <TextView
                android:id="@+id/title_weekly_comparison"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weekly_comparison"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/light_purple_gradient"
                android:layout_marginBottom="16dp">

                <!-- Bar Chart -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/bar_chart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="16dp" />

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginEnd="16dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@color/income_text"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Income"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@color/expense_text"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expense"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Spending Breakdown Section -->
            <TextView
                android:id="@+id/title_spending_breakdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/spending_breakdown"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/light_purple_gradient"
                android:layout_marginBottom="16dp">

                <!-- Pie Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="16dp">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_chart"
                        android:layout_width="200dp"
                        android:layout_height="200dp" />

                </LinearLayout>

                <!-- Total Expense -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/total"
                        android:textSize="16sp"
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/value_total_expense_breakdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LKR 44,540"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                </LinearLayout>

                <!-- Category List -->
                <LinearLayout
                    android:id="@+id/category_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Food -->
                    <LinearLayout
                        android:tag="Food"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/category_food" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/food"
                            android:textSize="14sp"
                            android:textColor="#000000"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_date_food"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 Apr 2019"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_amount_food"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 450.50"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_percentage_food"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42%"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_gravity="center_vertical" />

                    </LinearLayout>

                    <!-- Transport -->
                    <LinearLayout
                        android:tag="Transport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/category_transport" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Transport"
                            android:textSize="14sp"
                            android:textColor="#000000"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_date_transport"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 Apr 2019"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_amount_transport"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 250.50"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_percentage_transport"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25%"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_gravity="center_vertical" />

                    </LinearLayout>

                    <!-- Entertainment -->
                    <LinearLayout
                        android:tag="Entertainment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/category_entertainment" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/entertainment"
                            android:textSize="14sp"
                            android:textColor="#000000"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_date_entertainment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 Apr 2019"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_amount_entertainment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 459.50"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_percentage_entertainment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42%"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_gravity="center_vertical" />

                    </LinearLayout>

                    <!-- Bills -->
                    <LinearLayout
                        android:tag="Bills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/category_bills" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bills"
                            android:textSize="14sp"
                            android:textColor="#000000"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_date_bills"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 Apr 2019"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_amount_bills"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 950.50"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_percentage_bills"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42%"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_gravity="center_vertical" />

                    </LinearLayout>

                    <!-- Other -->
                    <LinearLayout
                        android:tag="Others"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/category_others" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/others"
                            android:textSize="14sp"
                            android:textColor="#000000"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_date_others_expense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 Apr 2019"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_amount_others_expense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 950.50"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_percentage_others_expense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42%"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_gravity="center_vertical" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Income Breakdown Section -->
            <TextView
                android:id="@+id/title_income_breakdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Income Breakdown"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/light_purple_gradient"
                android:layout_marginBottom="16dp">

                <!-- Pie Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="16dp">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_chart_income"
                        android:layout_width="200dp"
                        android:layout_height="200dp" />

                </LinearLayout>

                <!-- Total Income -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total"
                        android:textSize="16sp"
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/value_total_income_breakdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs 45,520"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                </LinearLayout>

                <!-- Income Category List -->
                <LinearLayout
                    android:id="@+id/income_category_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Salary -->
                    <LinearLayout
                        android:tag="Salary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/category_salary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Salary"
                            android:textSize="14sp"
                            android:textColor="#000000"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_date_salary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 Apr 2019"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_amount_salary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 460.50"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_percentage_salary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42%"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_gravity="center_vertical" />

                    </LinearLayout>

                    <!-- Freelance -->
                    <LinearLayout
                        android:tag="Freelance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/category_freelance" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Freelance"
                            android:textSize="14sp"
                            android:textColor="#000000"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_date_freelance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14 Apr 2019"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_amount_freelance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 459.50"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/category_percentage_freelance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42%"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_gravity="center_vertical" />

                    </LinearLayout>

                    <!-- Interest Money -->
                    <LinearLayout
                        android:tag="Interest Money"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <ImageView
