<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/onBoardScreen3Bg"
        android:layout_width="match_parent"
        android:layout_height="600dp"
        android:src="@drawable/get_start_bg"/>

    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="35dp"
        android:layout_alignParentBottom="true">



        <TextView
            android:id="@+id/textView1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Your money , your rules — let's start building the future you deserve"
            android:textSize="20sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Track your money flows,balance,and everyday transactions on the go."
            android:textSize="15sp"
            android:textAlignment="center"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Get Started"
            android:id="@+id/getStartedButton"
            android:textSize="18sp"
            android:backgroundTint="@color/purple"
            android:textColor="@color/white"
            app:cornerRadius="20dp"/>


    </LinearLayout>

</RelativeLayout>